# Enforce 2FA for authentication on publish (must be configured on the npm
# account as well: `npm profile enable-2fa auth-and-writes`).
always-auth=true

# Require provenance attestation on every publish. This makes npm record
# (via Sigstore) where the package was built from — the GitHub Actions run
# URL, commit SHA, and build steps. Consumers can verify with:
#   npm view payclaw --json | jq .signatures
# and reject installs lacking a matching attestation.
#
# Supply-chain defense: if someone compromises our npm account and tries to
# publish a poisoned version from their laptop, the version won't have a
# provenance trail, and security-aware users will catch it.
provenance=true
